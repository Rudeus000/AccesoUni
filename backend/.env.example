# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Clave SECRETA service_role (Settings → API en Supabase). El backend FastAPI la usa para operar
# como BFF (inserts/lecturas que no pueden hacerse solo con RLS del rol anon).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
# Opcional: clave publicable (anon / sb_publishable_...) para `/extension-login` (token JWT para la extensión). No sustituye a service_role.
SUPABASE_ANON_KEY=

# API
API_HOST=0.0.0.0
API_PORT=8000

# Email SMTP (para enviar el reporte mensual)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=you@example.com
MAIL_PASS=your_app_password_or_free_provider_password
MAIL_FROM=AccesoUni <you@example.com>

# Si luego ciframos email/otros datos en reposo, usaremos esta clave.
DATA_ENC_KEY=

